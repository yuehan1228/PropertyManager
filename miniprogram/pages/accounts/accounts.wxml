<view class="page-accounts">
  <view class="page-header flex justify-between items-center p-md">
    <text class="page-title">账户管理</text>
    <button class="btn btn-primary btn-sm" bindtap="onAdd">+ 添加账户</button>
  </view>

  <view wx:if="{{accounts.length > 0}}">
    <account-item
      wx:for="{{accounts}}"
      wx:key="id"
      id="{{item.id}}"
      label="{{item.label}}"
      bank="{{item.bank_name}}"
      balance="{{item.balance}}"
      bindtap="onEdit"
    />
  </view>
  <empty-state wx:else message="暂无账户" tip="添加储蓄卡开始追踪资产" />

  <!-- 编辑表单弹层 -->
  <view class="modal-overlay" wx:if="{{showForm}}" bindtap="onCloseForm">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{editingAccount ? '编辑账户' : '添加账户'}}</view>

      <view class="form-group">
        <text class="form-label">标识 *</text>
        <input class="form-input" placeholder="如：招行工资卡" value="{{form.label}}"
               data-field="label" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">银行名称</text>
        <input class="form-input" placeholder="如：招商银行" value="{{form.bank_name}}"
               data-field="bank_name" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">当前余额</text>
        <input class="form-input" type="digit" placeholder="0.00" value="{{form.balance}}"
               data-field="balance" bindinput="onFormInput" />
      </view>
      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="可选" value="{{form.remark}}"
               data-field="remark" bindinput="onFormInput" />
      </view>

      <view class="form-actions flex justify-between gap-sm">
        <button class="btn btn-outline flex-1" bindtap="onCloseForm">取消</button>
        <button class="btn btn-primary flex-1" bindtap="onFormSubmit">保存</button>
      </view>
      <view class="text-center mt-sm" wx:if="{{editingAccount}}">
        <text class="btn btn-ghost btn-sm" bindtap="onDelete" style="color:#ef4444;">删除账户</text>
      </view>
    </view>
  </view>
</view>
