<view class="page-fund-detail" wx:if="{{fund}}">
  <!-- 基本信息 -->
  <view class="card">
    <view class="flex justify-between items-center">
      <view class="flex-1">
        <view class="fund-name">{{fund.name || fund.code}}</view>
        <view class="fund-code">{{fund.code}}</view>
      </view>
      <view class="text-right">
        <view class="fund-nav-value">{{fmtNav(fund.nav)}}</view>
        <view class="{{fund.daily_change >= 0 ? 'amount-up' : 'amount-down'}}">
          {{fmtChange(fund.daily_change)}}%
        </view>
      </view>
    </view>
    <view class="divider" />
    <view class="flex justify-between">
      <view class="info-item">
        <text class="info-label">类型</text>
        <text class="info-value">{{typeLabel(fund.fund_type)}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">确认周期</text>
        <text class="info-value">{{fund.settle_cycle}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">赎回到账</text>
        <text class="info-value">{{fund.redeem_cycle}}</text>
      </view>
    </view>
    <view class="divider" wx:if="{{fund.acc_nav}}" />
    <view class="flex justify-between" wx:if="{{fund.acc_nav}}">
      <view class="info-item">
        <text class="info-label">累计净值</text>
        <text class="info-value">{{fmtNav(fund.acc_nav)}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">净值日期</text>
        <text class="info-value">{{fund.nav_date || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 操作 -->
  <view class="actions-row flex justify-between">
    <button class="btn btn-primary flex-1" bindtap="onSyncFund">🔄 同步数据</button>
  </view>

  <!-- 净值走势 -->
  <view class="section-title">近期净值</view>
  <view class="card">
    <view wx:if="{{navHistory.length > 0}}">
      <view class="nav-row flex justify-between" wx:for="{{navHistory}}" wx:key="nav_date">
        <text>{{item.nav_date}}</text>
        <text class="font-mono">{{fmtNav(item.unit_nav)}}</text>
        <text class="{{item.daily_change >= 0 ? 'amount-up' : 'amount-down'}}">
          {{item.daily_change !== null ? fmtChange(item.daily_change) + '%' : '--'}}
        </text>
      </view>
    </view>
    <empty-state wx:else message="暂未获取净值历史" />
  </view>
</view>
