.fund-name {
  font-size: 32rpx;
  font-weight: 600;
}
.fund-code {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}
.fund-nav-value {
  font-size: 40rpx;
  font-weight: 700;
}
.info-item {
  flex: 1;
}
.info-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}
.info-value {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 4rpx;
}
.actions-row {
  gap: 16rpx;
  margin: 24rpx;
}
.section-title {
  margin: 24rpx 24rpx 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.nav-row {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 26rpx;
}
.nav-row:last-child {
  border-bottom: none;
}
.font-mono {
  font-family: 'Courier New', monospace;
}
