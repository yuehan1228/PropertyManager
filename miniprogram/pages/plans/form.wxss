.form-section {
  margin-bottom: 16rpx;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #374151;
}
.form-group {
  margin-bottom: 20rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}
.form-input, .picker-value {
  height: 80rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}
.picker-value.placeholder {
  color: #9ca3af;
}
.radio-row {
  padding: 12rpx 0;
  gap: 12rpx;
  font-size: 28rpx;
}
.form-actions {
  padding-top: 24rpx;
}
/* 基金持仓概览 */
.fund-summary {
  background: #f0f9ff;
  border: 1rpx solid #bae6fd;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}
.summary-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0369a1;
  margin-bottom: 16rpx;
}
.summary-row {
  padding: 8rpx 0;
}
.summary-label {
  font-size: 24rpx;
  color: #6b7280;
}
.summary-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}
.summary-empty {
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
}
