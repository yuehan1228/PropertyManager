<view class="page-plan-form">
  <view class="form-section card">
    <view class="form-group">
      <text class="form-label">计划名称 *</text>
      <input class="form-input" placeholder="如：每月工资定投" value="{{form.plan_name}}"
             data-field="plan_name" bindinput="onInput" />
    </view>

    <!-- 目标基金 picker -->
    <view class="form-group">
      <text class="form-label">目标基金 *</text>
      <picker mode="selector" range="{{funds}}" range-key="name" bindchange="onFundPickerChange">
        <view class="picker-value">{{selectedFundDisplay}}</view>
      </picker>
    </view>

    <!-- 扣款账户 picker -->
    <view class="form-group">
      <text class="form-label">扣款账户 *</text>
      <picker mode="selector" range="{{accounts}}" range-key="label" bindchange="onAccountPickerChange">
        <view class="picker-value">{{selectedAccountDisplay}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">每次金额 *</text>
      <input class="form-input" type="digit" placeholder="0.00" value="{{form.amount}}"
             data-field="amount" bindinput="onInput" />
    </view>
  </view>

  <!-- 扣款频率 -->
  <view class="form-section card">
    <view class="section-label">扣款频率</view>
    <radio-group bindchange="onRadioChange">
      <label class="radio-row flex items-center"
             wx:for="{{freqOptions}}" wx:key="value">
        <radio value="{{item.value}}" checked="{{form.frequency === item.value}}" color="#0f3460" />
        <text>{{item.label}}</text>
      </label>
    </radio-group>

    <!-- 每月执行日 picker -->
    <view class="form-group" wx:if="{{form.frequency === 'monthly'}}">
      <text class="form-label">每月执行日</text>
      <picker mode="selector" range="{{dayOptions}}" bindchange="onDayPickerChange">
        <view class="picker-value">{{form.execute_day}} 日</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">开始日期</text>
      <input class="form-input" placeholder="YYYY-MM-DD" value="{{form.start_date}}"
             data-field="start_date" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">总期数（留空无限）</text>
      <input class="form-input" type="number" placeholder="如：12" value="{{form.total_rounds}}"
             data-field="total_rounds" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="可选" value="{{form.remark}}"
             data-field="remark" bindinput="onInput" />
    </view>
  </view>

  <view class="form-actions p-md">
    <button class="btn btn-primary btn-block" bindtap="onSubmit" loading="{{submitting}}">
      保存
    </button>
  </view>
</view>
