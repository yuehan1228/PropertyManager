<view class="page-plans">
  <view class="page-header flex justify-between items-center p-md">
    <text class="page-title">定投计划</text>
    <button class="btn btn-primary btn-sm" bindtap="goForm">+ 新建计划</button>
  </view>

  <!-- 标签切换 -->
  <view class="tabs flex">
    <view class="tab-item {{tab === 'active' ? 'active' : ''}}" data-tab="active" bindtap="onTabChange">
      进行中
    </view>
    <view class="tab-item {{tab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="onTabChange">
      全部
    </view>
  </view>

  <view wx:if="{{plans.length > 0}}">
    <view class="card plan-card" wx:for="{{plans}}" wx:key="id">
      <view class="flex justify-between items-center">
        <view class="flex-1">
          <view class="plan-name">{{item.plan_name}}</view>
          <view class="plan-info">
            <text class="tag tag-blue">{{item.fund_code}}</text>
            <text class="plan-amount">¥{{item.amount.toFixed(2)}} / {{freqLabel(item.frequency)}}</text>
          </view>
        </view>
        <view class="plan-status">
          <text class="tag {{item.status === 'active' ? 'tag-green' : 'tag-gray'}}">
            {{item.status === 'active' ? '运行中' : item.status === 'paused' ? '已暂停' : '已停止'}}
          </text>
        </view>
      </view>
      <view class="divider" />
      <view class="flex justify-between items-center">
        <view class="plan-progress">
          已完成 {{item.completed_rounds}}{{item.total_rounds ? '/' + item.total_rounds : ''}} 期
        </view>
        <view class="flex gap-xs">
          <button class="btn btn-outline btn-sm" data-id="{{item.id}}" bindtap="goForm">编辑</button>
          <button class="btn btn-outline btn-sm" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="onToggleStatus">
            {{item.status === 'active' ? '暂停' : '启用'}}
          </button>
          <button class="btn btn-ghost btn-sm" data-id="{{item.id}}" bindtap="onDelete">删除</button>
        </view>
      </view>
      <view class="plan-next" wx:if="{{item.next_execute_date && item.status === 'active'}}">
        下次执行: {{item.next_execute_date}}
      </view>
    </view>
  </view>
  <empty-state wx:else message="暂无定投计划" tip="创建自动定投，省心省力" />
</view>
