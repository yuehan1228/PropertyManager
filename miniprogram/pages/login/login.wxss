/* 登录页 */
.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f3460 0%, #16213e 50%, #f5f6fa 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}
.login-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.login-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}
.login-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

.login-body {
  width: 80%;
  max-width: 600rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 24rpx;
}
.login-btn::after {
  border: none;
}

.primary-btn {
  background: #07c160;
  color: #fff;
}
.primary-btn:active {
  background: #06ad56;
}

.dev-btn {
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.8);
  border: 2rpx solid rgba(255,255,255,0.2);
}
.dev-btn:active {
  background: rgba(255,255,255,0.25);
}

.error-msg {
  text-align: center;
  color: #ff6b6b;
  font-size: 26rpx;
  margin: 16rpx 0;
  padding: 12rpx;
  background: rgba(255,107,107,0.1);
  border-radius: 8rpx;
}

.login-tips {
  text-align: center;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.login-tips text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}
