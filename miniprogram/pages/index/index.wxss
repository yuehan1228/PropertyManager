/* 看板页 */
.page-index {
  padding-bottom: 40rpx;
}

/* 头部资产卡片 */
.header-card {
  background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
  margin: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
  color: #fff;
}
.header-label {
  font-size: 26rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}
.header-amount {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}
.header-sub-item {
  flex: 1;
}
.sub-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}
.sub-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 4rpx;
}
.header-asset-split {
  border-top: 1rpx solid rgba(255,255,255,0.15);
  padding-top: 20rpx;
}
.split-item {
  flex: 1;
}
.split-label {
  font-size: 24rpx;
  opacity: 0.7;
}
.split-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 4rpx;
}
.header-pending {
  border-top: 1rpx solid rgba(255,255,255,0.15);
  padding-top: 16rpx;
}
.pending-label {
  font-size: 24rpx;
  opacity: 0.7;
}
.pending-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fbbf24;
}
.refresh-time {
  text-align: center;
  font-size: 22rpx;
  opacity: 0.5;
  margin-top: 16rpx;
}

/* 快捷操作 */
.actions-row {
  margin: 0 24rpx;
  gap: 16rpx;
}
.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: none;
  font-size: inherit;
  line-height: 1.4;
}
.action-btn::after { border: none; }
.action-icon {
  font-size: 40rpx;
}
.action-text {
  font-size: 24rpx;
  color: #6b7280;
}

/* 章节标题 */
.section-title {
  margin: 32rpx 24rpx 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
}

/* 持仓行 */
.holding-row {
  margin: 8rpx 24rpx;
}
.holding-name {
  font-size: 28rpx;
  font-weight: 500;
}
.holding-shares {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}
.holding-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 图表占位 */
.chart-placeholder {
  height: 200rpx;
  color: #9ca3af;
  font-size: 26rpx;
}
